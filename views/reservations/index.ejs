<% layout("/layouts/boilerplate") %>

<div class="reservations-page py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
        <div>
            <h2 class="mb-1">My Reservations</h2>
            <p class="text-muted mb-0">All properties reserved with <%= currUser.username %>'s account.</p>
        </div>
        <a href="/listings" class="btn btn-outline-dark align-self-start">Explore more stays</a>
    </div>

    <% if(reservations.length === 0) { %>
        <div class="empty-reservations text-center">
            <i class="fa-regular fa-calendar-xmark"></i>
            <h4 class="mt-3">No reservations yet</h4>
            <p class="text-muted">When you reserve a property, it will appear here.</p>
            <a href="/listings" class="btn btn-danger">Find a property</a>
        </div>
    <% } else { %>
        <div class="row g-4">
            <% for(const reservation of reservations) { %>
                <div class="col-12 col-xl-6">
                    <div class="card reservation-card h-100">
                        <div class="row g-0 h-100">
                            <div class="col-md-5">
                                <a href="/listings/<%= reservation.listing._id %>">
                                    <img src="<%= reservation.listing.image.url %>" class="reservation-image"
                                        alt="<%= reservation.listing.title %>">
                                </a>
                            </div>
                            <div class="col-md-7">
                                <div class="card-body d-flex flex-column h-100">
                                    <h4 class="card-title"><%= reservation.listing.title %></h4>
                                    <p class="text-muted mb-3">
                                        <i class="fa-solid fa-location-dot"></i>
                                        <%= reservation.listing.location %>, <%= reservation.listing.country %>
                                    </p>

                                    <div class="reservation-details mb-3">
                                        <div>
                                            <span>Check-in</span>
                                            <strong><%= reservation.checkIn.toLocaleDateString("en-IN", {
                                                day: "numeric", month: "short", year: "numeric", timeZone: "UTC"
                                            }) %></strong>
                                        </div>
                                        <div>
                                            <span>Check-out</span>
                                            <strong><%= reservation.checkOut.toLocaleDateString("en-IN", {
                                                day: "numeric", month: "short", year: "numeric", timeZone: "UTC"
                                            }) %></strong>
                                        </div>
                                        <div>
                                            <span>Guests</span>
                                            <strong><%= reservation.guests %></strong>
                                        </div>
                                        <div>
                                            <span>Total</span>
                                            <strong>&#8377;<%= reservation.totalPrice.toLocaleString("en-IN") %></strong>
                                        </div>
                                    </div>

                                    <div class="d-flex flex-wrap gap-2 mt-auto">
                                        <a href="/listings/<%= reservation.listing._id %>"
                                            class="btn btn-sm btn-outline-dark">View property</a>
                                        <a href="/reservations/<%= reservation._id %>/edit"
                                            class="btn btn-sm btn-danger">Edit reservation</a>
                                        <form action="/reservations/<%= reservation._id %>?_method=DELETE" method="POST"
                                            onsubmit="return confirm('Are you sure you want to unreserve this property?');">
                                            <button class="btn btn-sm btn-outline-danger">Unreserve</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } %>
</div>
